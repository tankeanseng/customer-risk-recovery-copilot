APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-5.4-mini
OPENAI_MODEL_STRONG=gpt-5.1
OPENAI_MODEL_CHEAP=gpt-5.4-nano

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=customer-risk-recovery-copilot-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LiteLLM (optional later)
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=

# AWS deployment/runtime
AWS_REGION=ap-southeast-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Frontend origins allowed to call the API.
FRONTEND_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Local runtime state persistence (use S3-backed storage later in AWS deployment).
APP_STATE_DIR=backend/runtime_state
